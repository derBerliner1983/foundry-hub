# Cloud-API-Keys (leer lassen = es greift der Mock-Provider, alles läuft trotzdem)
# Alle Schlüssel lassen sich auch bequem in der GUI unter „Zugangsdaten" setzen.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Weitere Provider (optional)
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Optional: Brave Search API-Key für den Such-MCP-Server (leer = DuckDuckGo)
BRAVE_API_KEY=

# Benachrichtigungen per Chat (optional, Webhook-URLs)
SLACK_WEBHOOK=
DISCORD_WEBHOOK=

# Sicherheit
# Hauptschlüssel zur Verschlüsselung der gespeicherten Zugangsdaten.
# Leer = es wird einmalig ein Zufallsschlüssel unter /data/.foundryhub_key erzeugt.
# Für portable Backups einen festen Wert setzen und sicher aufbewahren!
APP_SECRET_KEY=
# Optionale IP-Allowlist (CSV, einzelne IPs oder CIDR, z. B. 10.0.0.0/8,1.2.3.4).
# Leer = kein IP-Filter (Zugriff wird ohnehin per Login geschützt).
IP_ALLOWLIST=

# E-Mail senden (SMTP) – z. B. für Benachrichtigungen & Assistent
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_STARTTLS=true

# E-Mail lesen (IMAP) – für den Daily-Assistant (leer = wie SMTP_USER/PASS)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_SSL=true

# Wohin Benachrichtigungen gehen (leer = in der App unter Einstellungen setzen)
NOTIFY_EMAIL=

# Standardmodelle
DEFAULT_CHEF_PROVIDER=claude
DEFAULT_CHEF_MODEL=claude-opus-4-8
DEFAULT_WORKER_PROVIDER=claude
DEFAULT_WORKER_MODEL=claude-sonnet-4-6

# Lokale Modelle über Ollama
OLLAMA_BASE_URL=http://ollama:11434
# Beim Start NUR ziehen, wenn noch kein Modell installiert ist (leer = nie)
OLLAMA_AUTO_MODEL=llama3.2:1b

# Wenn true: ohne passenden Key antwortet ein Mock, damit das System lauffähig bleibt
ALLOW_MOCK_FALLBACK=true

# Code-Werkstatt: Agenten dürfen echte Dateien schreiben und Befehle ausführen
ENABLE_CODE_EXECUTION=true
EXEC_TIMEOUT=60

# Isolierter Build-Container (per docker compose mitgestartet).
# Leer lassen = Befehle laufen lokal im App-Container.
SANDBOX_URL=http://sandbox:8800
SANDBOX_TIMEOUT=600
