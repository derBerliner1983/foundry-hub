# Cloud-API-Keys (leer lassen = es greift der Mock-Provider, alles läuft trotzdem)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Standardmodelle
DEFAULT_CHEF_PROVIDER=claude
DEFAULT_CHEF_MODEL=claude-opus-4-8
DEFAULT_WORKER_PROVIDER=claude
DEFAULT_WORKER_MODEL=claude-sonnet-4-6

# Lokale Modelle über Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Wenn true: ohne passenden Key antwortet ein Mock, damit das System lauffähig bleibt
ALLOW_MOCK_FALLBACK=true
