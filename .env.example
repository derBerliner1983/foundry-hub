# Cloud-API-Keys (leer lassen = es greift der Mock-Provider, alles läuft trotzdem)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: Brave Search API-Key für den Such-MCP-Server (leer = DuckDuckGo)
BRAVE_API_KEY=

# E-Mail senden (SMTP) – z. B. für Benachrichtigungen & Assistent
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_STARTTLS=true

# E-Mail lesen (IMAP) – für den Daily-Assistant (leer = wie SMTP_USER/PASS)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_SSL=true

# Wohin Benachrichtigungen gehen (leer = in der App unter Einstellungen setzen)
NOTIFY_EMAIL=

# Standardmodelle
DEFAULT_CHEF_PROVIDER=claude
DEFAULT_CHEF_MODEL=claude-opus-4-8
DEFAULT_WORKER_PROVIDER=claude
DEFAULT_WORKER_MODEL=claude-sonnet-4-6

# Lokale Modelle über Ollama
OLLAMA_BASE_URL=http://ollama:11434
# Beim Start NUR ziehen, wenn noch kein Modell installiert ist (leer = nie)
OLLAMA_AUTO_MODEL=llama3.2:1b

# Wenn true: ohne passenden Key antwortet ein Mock, damit das System lauffähig bleibt
ALLOW_MOCK_FALLBACK=true

# Code-Werkstatt: Agenten dürfen echte Dateien schreiben und Befehle ausführen
ENABLE_CODE_EXECUTION=true
EXEC_TIMEOUT=60
